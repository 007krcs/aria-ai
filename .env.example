# ============================================================
# ARIA Environment Configuration
# Copy to .env and fill in your keys
# ============================================================

# ── LLM Provider (auto = first available key wins) ───────────
# Priority: groq → openai → anthropic → gemini → together → ollama
LLM_PROVIDER=auto

# ── Groq (FREE — fastest, recommended) ──────────────────────
# Get key: console.groq.com  |  14,400 req/day free
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ── OpenAI (optional) ────────────────────────────────────────
# Get key: platform.openai.com
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude (optional) ──────────────────────────────
# Get key: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Google Gemini (FREE tier available) ──────────────────────
# Get key: aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Together.ai (FREE models available) ──────────────────────
# Get key: api.together.ai
TOGETHER_API_KEY=your_together_key_here
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# ── Server ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ARIA_ENV=cloud

# ── Voice ────────────────────────────────────────────────────
VOICE_DEFAULT=en-IN-NeerjaNeural

# ── Optional ─────────────────────────────────────────────────
ARIA_SECRET_KEY=change_this_to_random_string
